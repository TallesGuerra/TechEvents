<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="7dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Date block (ticket-style) -->
    <LinearLayout
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_date_block"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvWeekday"
            style="@style/Text.Mono.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:text="SEX"/>

        <TextView
            android:id="@+id/tvDay"
            style="@style/Text.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="30sp"
            android:text="22"/>

        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/jet_mono"
            android:textColor="@color/on_surface_variant"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:text="MAI"/>
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <!-- Category + format row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="90dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:background="@drawable/bg_chip_category"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:fontFamily="@font/jet_mono"
                android:textColor="@color/on_surface_variant"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:text="Frontend"/>

            <TextView
                android:id="@+id/tvFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:fontFamily="@font/jakarta_bold"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:text="PRESENCIAL"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvSoldOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_category"
                android:backgroundTint="@color/primary"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:fontFamily="@font/jet_mono"
                android:textColor="@color/on_primary"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:text="ESGOTADO"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="19sp"
            android:text="React Brasil Summit 2026"/>

        <!-- Meta row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="4dp"
                android:fontFamily="@font/jakarta"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:text="09:00"/>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:fontFamily="@font/jakarta"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:text="Centro de Convenções"/>

            <TextView
                android:id="@+id/tvEnrolled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/jakarta"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:text="312/480"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
