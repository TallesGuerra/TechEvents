<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jet_mono"
        android:letterSpacing="0.18"
        android:text="TECH · EVENTS"
        android:textAllCaps="true"
        android:textColor="@color/on_surface_variant"
        android:textSize="11sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/instrument_serif"
        android:gravity="center"
        android:includeFontPadding="false"
        android:letterSpacing="-0.03"
        android:lineSpacingMultiplier="0.92"
        android:text="A próxima\nmeetup, sua."
        android:textColor="@color/on_surface"
        android:textSize="56sp"/>

    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_marginTop="22dp"
        android:background="@color/accent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/jakarta"
        android:gravity="center"
        android:text="Descubra eventos tech perto de você"
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp"/>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:indeterminateTint="@color/primary"/>

</LinearLayout>
