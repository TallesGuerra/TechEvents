<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp">

            <!-- Top action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:iconPadding="0dp"
                    app:icon="@android:drawable/ic_media_previous"
                    app:iconTint="@color/on_surface"
                    app:strokeColor="@color/divider"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavorite"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:iconPadding="0dp"
                    app:icon="@android:drawable/btn_star_big_off"
                    app:iconTint="@color/on_surface"
                    app:strokeColor="@color/divider"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:iconPadding="0dp"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconTint="@color/on_surface"
                    app:strokeColor="@color/divider"/>
            </LinearLayout>

            <!-- Hero card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_card"
                android:orientation="vertical"
                android:padding="22dp"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_category"
                        android:backgroundTint="#22FFFFFF"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:fontFamily="@font/jet_mono"
                        android:textColor="@color/on_primary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:text="Frontend"/>

                    <TextView
                        android:id="@+id/tvFormat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_chip_category"
                        android:backgroundTint="@color/accent"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:fontFamily="@font/jet_mono"
                        android:textColor="@color/on_accent"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:text="Presencial"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/instrument_serif"
                    android:textColor="@color/on_primary"
                    android:textSize="32sp"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.0"
                    android:text="React Brasil Summit 2026"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#22FFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/instrument_serif"
                            android:textColor="@color/on_primary"
                            android:textSize="42sp"
                            android:includeFontPadding="false"
                            android:text="22"/>

                        <TextView
                            android:id="@+id/tvDateLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/jet_mono"
                            android:textColor="#B3FAF8F1"
                            android:textSize="10sp"
                            android:letterSpacing="0.18"
                            android:text="MAI · SEX"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#22FFFFFF"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jet_mono"
                            android:textColor="#B3FAF8F1"
                            android:textSize="10sp"
                            android:letterSpacing="0.15"
                            android:text="HORÁRIO"/>

                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/jakarta_bold"
                            android:textColor="@color/on_primary"
                            android:textSize="16sp"
                            android:text="09:00"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Location card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_chip_category">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/on_surface"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Mono.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOCAL"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/jakarta_bold"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:text="Centro de Convenções • São Paulo"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMap"
                    style="@style/Button.Ghost"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="Mapa"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- About section -->
            <TextView
                style="@style/Text.Mono.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:textSize="11sp"
                android:text="SOBRE O EVENTO"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/instrument_serif"
                android:textColor="@color/on_surface"
                android:textSize="19sp"
                android:lineSpacingMultiplier="1.35"
                android:text="Dois dias de talks intensivos sobre o ecossistema React: Server Components, suspense, e o futuro do framework."/>

            <!-- Capacity card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCapacity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/jakarta_bold"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:text="312 de 480 vagas"/>

                    <TextView
                        android:id="@+id/tvCapacityPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jet_mono"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:text="65%"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressCapacity"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="65"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface_alt"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Sticky CTA -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    style="@style/Text.Mono.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRATUITO"/>

                <TextView
                    style="@style/Text.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:text="R$ 0,00"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnroll"
                style="@style/Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:paddingHorizontal="22dp"
                android:text="Inscrever-me"
                android:textSize="15sp"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
